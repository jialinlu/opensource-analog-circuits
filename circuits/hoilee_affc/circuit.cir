xm12 VOUT net050 VDDA VDDA sky130_fd_pr__pfet_01v8 l='MOSFET_12_1_L_gmf2_PMOS' w='MOSFET_12_1_W_gmf2_PMOS*1' m='MOSFET_12_1_M_gmf2_PMOS'
xm7 net049 net013 VDDA VDDA sky130_fd_pr__pfet_01v8 l='MOSFET_0_8_L_BIASCM_PMOS' w='MOSFET_0_8_W_BIASCM_PMOS*1' m='MOSFET_0_8_M_BIASCM_PMOS'
