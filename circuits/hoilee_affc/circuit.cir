.subckt hoilee_affc_pin_3 gnda vdda vinn vinp vout
xm62 net050 net2 VDDA VDDA sky130_fd_pr__pfet_01v8 l='MOSFET_59_2_L_HSBCM_PMOS' w='MOSFET_59_2_W_HSBCM_PMOS*1' m='MOSFET_59_2_M_HSBCM_PMOS'
